{
  "name": "tasm-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "preview:e2e": "VITE_E2E=true vite preview --host 127.0.0.1 --port 4173",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run build && npm run test:e2e",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "knip": "^6.11.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
